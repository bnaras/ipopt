#!/bin/sh

# Anticonf-style system dependency discovery, following the r-lib/openssl
# package pattern.  Prefer pkg-config, allow manual INCLUDE_DIR/LIB_DIR
# overrides, and provide concrete install hints on failure.

PKG_CONFIG_NAME="ipopt"
PKG_DEB_NAME="coinor-libipopt-dev"
PKG_RPM_NAME="coin-or-Ipopt-devel"
PKG_BREW_NAME="ipopt"
PKG_TEST_FILE="tools/version.c"
PKG_LIBS="-lipopt"
PKG_CFLAGS=""

# Use pkg-config if available.
pkg-config ${PKG_CONFIG_NAME} ${MINVERSION} 2>/dev/null
if [ $? -eq 0 ]; then
  PKGCONFIG_CFLAGS=`pkg-config --cflags ${PKG_CONFIG_NAME}`
  PKGCONFIG_LIBS=`pkg-config --libs ${PKG_CONFIG_NAME}`
fi

if [ "$INCLUDE_DIR" ] || [ "$LIB_DIR" ]; then
  echo "Found INCLUDE_DIR and/or LIB_DIR!"
  PKG_CFLAGS="-I$INCLUDE_DIR $PKG_CFLAGS"
  PKG_LIBS="-L$LIB_DIR $PKG_LIBS"
elif [ "$PKGCONFIG_CFLAGS" ] || [ "$PKGCONFIG_LIBS" ]; then
  echo "Found pkg-config cflags and libs!"
  PKG_CFLAGS=${PKGCONFIG_CFLAGS}
  PKG_LIBS=${PKGCONFIG_LIBS}
elif [ `uname` = "Darwin" ]; then
  test ! "$CI" && brew --version 2>/dev/null
  if [ $? -eq 0 ]; then
    BREWDIR=`brew --prefix`
    PKG_CFLAGS="-I$BREWDIR/opt/ipopt/include/coin-or"
    PKG_LIBS="-L$BREWDIR/opt/ipopt/lib $PKG_LIBS"
  fi
fi

CC=`${R_HOME}/bin/R CMD config CC`
CFLAGS=`${R_HOME}/bin/R CMD config CFLAGS`
CPPFLAGS=`${R_HOME}/bin/R CMD config CPPFLAGS`

echo "Using PKG_CFLAGS=$PKG_CFLAGS"

${CC} ${CPPFLAGS} ${PKG_CFLAGS} ${CFLAGS} -E ${PKG_TEST_FILE} >/dev/null 2>configure.log

if [ $? -ne 0 ]; then
  echo "--------------------------- [ANTICONF] --------------------------------"
  echo "Configuration failed because Ipopt was not found. Try installing:"
  echo " * deb: $PKG_DEB_NAME (Debian, Ubuntu, etc)"
  echo " * rpm: $PKG_RPM_NAME (Fedora, CentOS, RHEL)"
  echo " * brew: $PKG_BREW_NAME (macOS)"
  echo "If Ipopt is already installed, check that 'pkg-config' is in your PATH"
  echo "and PKG_CONFIG_PATH contains an ipopt.pc file. If pkg-config is"
  echo "unavailable you can set INCLUDE_DIR and LIB_DIR manually via:"
  echo "R CMD INSTALL --configure-vars='INCLUDE_DIR=... LIB_DIR=...'"
  echo "-------------------------- [ERROR MESSAGE] ---------------------------"
  cat configure.log
  echo "--------------------------------------------------------------------"
  exit 1
fi

echo "Using PKG_LIBS=$PKG_LIBS"

sed -e "s|@cflags@|$PKG_CFLAGS|" -e "s|@libs@|$PKG_LIBS|" src/Makevars.in > src/Makevars

exit 0
